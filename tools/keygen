#!/usr/bin/env bash
# ============================================================
# PhoenixKey dev CLI — sinh secp256k1 keypair + ký GENESIS / ROTATE message.
# Wrapper chạy KeypairGenCli qua maven exec.
#
# Usage:
#   ./tools/keygen genesis
#   ./tools/keygen rotate <privKeyHex> <newPubKeyHex> [nonce]
#   ./tools/keygen sign   <privKeyHex> <message>
# ============================================================
set -eu

cd "$(dirname "$0")/.."

ARGS="$*"
if [ -z "$ARGS" ]; then
    ARGS="help"
fi

exec ./mvnw -q exec:java \
    -Dexec.mainClass="com.magiclamp.phoenixkey_db.tools.KeypairGenCli" \
    -Dexec.args="$ARGS"
