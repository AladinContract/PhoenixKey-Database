# ============================================================
# PhoenixKey-Server — Environment Variables
# ============================================================
# Copy thành .env và điền giá trị thật.
# TUYỆT ĐỐI KHÔNG commit .env vào git.
# Sau khi tạo: chmod 600 .env
#
# Cùng 1 file dùng cho dev + prod — chỉ giá trị khác nhau (xem chú thích DEV/PROD).
# ============================================================

# ─── Database (PostgreSQL) ──────────────────────────────────
# DB_HOST: app dùng để kết nối
#   - Chạy app trong compose:        postgres (compose tự override)
#   - Chạy app native ngoài Docker:  localhost
# DB_PORT: CHỈ dùng cho host-port mapping (truy cập từ máy host).
#   - Container-to-container trong compose LUÔN dùng port nội bộ 5432
#     (compose tự override, KHÔNG đọc giá trị này).
#   - Đổi DB_PORT khi máy host đã có postgres khác chiếm 5432.
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=phoenixkey
DB_PASSWORD=change_me_strong_password   # PROD: openssl rand -base64 24
POSTGRES_DB=phoenixkey

# Postgres tuning (điều chỉnh theo RAM server)
# Khuyến nghị: shared_buffers ≈ 25% RAM, effective_cache_size ≈ 75% RAM
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WORK_MEM=16MB
POSTGRES_LOG_MIN_DURATION=200ms
POSTGRES_MEM_LIMIT=2G

# ─── Redis ──────────────────────────────────────────────────
# REDIS_PORT: tương tự DB_PORT — chỉ dùng cho host-port mapping.
# Container-to-container luôn dùng 6379 nội bộ.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password  # PROD: openssl rand -base64 24

REDIS_MAXMEMORY=256mb
REDIS_MEM_LIMIT=512M

# ─── Spring Boot App ────────────────────────────────────────
# APP_BIND: interface Docker bind port app
#   - 0.0.0.0:    accept request từ ngoài (PROD nếu app expose trực tiếp)
#   - 127.0.0.1:  chỉ local (PROD khi có nginx/Traefik reverse proxy cùng máy)
APP_BIND=0.0.0.0
APP_PORT=8080
APP_MEM_LIMIT=2G

# ─── HashiCorp Vault — KMS (self-host trong compose) ─────────
# Vault chạy dev mode trong compose (storage inmem).
# vault-seed daemon tự re-seed từ FEE_WALLET_MNEMONIC + JWT_SECRET_BASE64
# bên dưới mỗi khi vault wipe (restart container) → app không bị down.
VAULT_ENABLED=true
VAULT_ADDR=http://vault:8200
VAULT_PORT=8200
VAULT_TOKEN=phoenixkey-dev-token   # match với VAULT_DEV_ROOT_TOKEN_ID hardcode trong compose
VAULT_NAMESPACE=                   # rỗng cho self-host

# ─── Secrets nguồn (vault-seed đẩy vào Vault) ────────────────
# Đây là SOURCE OF TRUTH — vault chỉ là cache layer cho app đọc.
# Production: backup .env (1Password/vault external) — mất file = mất ví fee.

# Fee wallet mnemonic 24 từ BIP-39, space-separated.
# DEV: bỏ trống → seeder dùng dummy test vector "abandon abandon ... art" (public, ai cũng spend).
# PROD: BẮT BUỘC điền — sinh bằng `./tools/keygen wallet`, fund ADA từ exchange.
FEE_WALLET_MNEMONIC=

# JWT secret 32-byte base64 (HMAC-SHA256 key cho session/temp/linked-device tokens).
# DEV: bỏ trống → seeder sinh random mỗi restart (session JWT cũ invalidate, user phải login lại).
# PROD: BẮT BUỘC điền — `openssl rand -base64 32` → save 1Password.
#       Đây là single-source-of-truth, KHÔNG được rotate trừ khi key bị lộ.
JWT_SECRET_BASE64=

# ─── Web (CORS) ──────────────────────────────────────────────
# Comma-separated origin list.
# DEV: http://localhost:3000,https://phoenixkey.me,https://staging.phoenixkey.me
# PROD: chỉ domain thật (vd: https://phoenixkey.me)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://phoenixkey.me,https://staging.phoenixkey.me

# ─── Cardano ─────────────────────────────────────────────────
# DEV: preprod testnet (free tADA từ faucet, dùng tools/keygen wallet)
# PROD: mainnet (cần Blockfrost mainnet API key + ADA thật)
CARDANO_NETWORK=preprod
BLOCKFROST_API_KEY=

# ─── Logging ─────────────────────────────────────────────────
# DEV: DEBUG hoặc INFO. PROD: INFO hoặc WARN.
LOG_LEVEL=INFO
