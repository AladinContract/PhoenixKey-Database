# ============================================================
# PhoenixKey Database — Environment Variables
# ============================================================
# Copy thành .env và điền giá trị thật.
# TUYỆT ĐỐI KHÔNG commit .env vào git.
# Sau khi tạo: chmod 600 .env
# ============================================================

# ─── Database (PostgreSQL) ──────────────────────────────────
# DB_HOST: Spring Boot dùng để kết nối
#   - Dev local (chạy app ngoài Docker):   localhost
#   - Docker Compose:                       postgres (tự override trong compose)
DB_HOST=localhost
DB_USERNAME=phoenixkey
DB_PASSWORD=change_me_strong_password

# Tên database (mặc định "phoenixkey")
POSTGRES_DB=phoenixkey

# Postgres tuning (điều chỉnh theo RAM server)
# Khuyến nghị: shared_buffers ≈ 25% RAM, effective_cache_size ≈ 75% RAM
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WORK_MEM=16MB
POSTGRES_LOG_MIN_DURATION=200ms
POSTGRES_MEM_LIMIT=2G

# ─── Redis ──────────────────────────────────────────────────
# Spring Boot config
REDIS_HOST=localhost
REDIS_PORT=6379
# BẮT BUỘC cho production — Redis không có password là lỗ hổng nghiêm trọng
REDIS_PASSWORD=change_me_redis_password

REDIS_MAXMEMORY=256mb
REDIS_MEM_LIMIT=512M

# ─── Spring Boot App ────────────────────────────────────────
# Bind address + port cho app container
#   - 0.0.0.0 (mặc định): accept request từ reverse proxy / internet
#   - 127.0.0.1: chỉ local (khi chạy sau reverse proxy cùng máy)
APP_BIND=0.0.0.0
APP_PORT=8084
APP_MEM_LIMIT=2G

# ─── HashiCorp Vault ─────────────────────────────────────────
# Vault chứa PEPPER (HMAC key) cho Blind Index.
# KHÔNG BAO GIỜ lưu pepper trong .env — chỉ đọc từ Vault.
VAULT_ENABLED=true
# Prod: dùng HCP Vault URL (https://xxxxx.cluster.hashicorp.cloud:8200)
# Dev:  http://host.docker.internal:8200
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your_vault_token_here

# Namespace cho HCP Vault (không bắt buộc)
VAULT_NAMESPACE=

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
