# ============================================================
# PhoenixKey-Server — Environment Variables
# ============================================================
# Copy thành .env và điền giá trị thật.
# TUYỆT ĐỐI KHÔNG commit .env vào git.
# Sau khi tạo: chmod 600 .env
# ============================================================

# ─── Database (PostgreSQL) ──────────────────────────────────
# DB_HOST: Spring Boot dùng để kết nối
#   - Dev local (chạy app ngoài Docker):   localhost
#   - Docker Compose:                       postgres (tự override trong compose)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=phoenixkey
DB_PASSWORD=change_me_strong_password
POSTGRES_DB=phoenixkey

# Postgres tuning (điều chỉnh theo RAM server)
# Khuyến nghị: shared_buffers ≈ 25% RAM, effective_cache_size ≈ 75% RAM
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WORK_MEM=16MB
POSTGRES_LOG_MIN_DURATION=200ms
POSTGRES_MEM_LIMIT=2G

# ─── Redis ──────────────────────────────────────────────────
# Spring Boot config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

REDIS_MAXMEMORY=256mb
REDIS_MEM_LIMIT=512M

# ─── Spring Boot App ────────────────────────────────────────
# Bind address + port cho app container
#   - 0.0.0.0 (mặc định): accept request từ reverse proxy / internet
#   - 127.0.0.1: chỉ local (khi chạy sau reverse proxy cùng máy)
APP_BIND=0.0.0.0
APP_PORT=8084
APP_MEM_LIMIT=2G

# ─── HashiCorp Vault — KMS chung cho mọi secret ──────────────
# Layout chuẩn (KV v2 mounted at secret/):
#   secret/phoenixkey/fee-wallet/mnemonic   { "words": [...] }
#   secret/phoenixkey/jwt/secret            { "key": "<base64-32-byte>" }
#   secret/phoenixkey/fcm/service-account   { "json": "..." }
#   secret/phoenixkey/apns/auth-key         { "key": "...", "keyId": "...", "teamId": "..." }
#
# Dev: docker-compose tự khởi Vault dev mode trên service `vault`.
#      Sau khi up, chạy: bash infrastructure/vault/seed-dev.sh để populate secrets.
# Prod: comment service `vault` trong docker-compose, set VAULT_ADDR trỏ HCP Vault.
VAULT_ENABLED=true
# Khi chạy app native (mvn spring-boot:run): http://localhost:8200
# Khi chạy app trong compose: http://vault:8200 (compose tự override)
VAULT_ADDR=http://localhost:8200
VAULT_PORT=8200
# DEV: phải để đúng "phoenixkey-dev-token" — match với VAULT_DEV_ROOT_TOKEN_ID
#      hardcode trong docker-compose (Vault dev mode không cho prefix hvs.*).
# PROD: set token HCP Vault thật (vd hvs.XXXXXXXX) — comment vault service trong compose.
VAULT_TOKEN=phoenixkey-dev-token
# Namespace chỉ cần cho HCP Vault multi-tenant
VAULT_NAMESPACE=

# ─── Web (Phase D) ───────────────────────────────────────────
# Comma-separated origin list cho CORS. Bao gồm dev localhost + prod domain.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://phoenixkey.me,https://staging.phoenixkey.me

# ─── Cardano (Phase B) ───────────────────────────────────────
CARDANO_NETWORK=preprod
# Blockfrost API key — có thể đặt trong Vault tại secret/phoenixkey/blockfrost/api-key
# hoặc giữ env (low-value secret).
BLOCKFROST_API_KEY=

# ─── Dev fallback (chỉ dùng khi VAULT_ENABLED=false) ─────────
# KHÔNG dùng cho prod — luôn để Vault làm SSoT.
# FEE_WALLET_MNEMONIC=word1 word2 ... word24
# PHOENIXKEY_JWT_SECRET=base64-encoded-32-byte-random

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
